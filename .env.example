NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clickpesa_shopify
SHOPIFY_APP_SCOPES=write_payment_gateways,write_payment_sessions
SHOPIFY_PAYMENTS_API_VERSION=2026-01
SHOPIFY_PAYMENTS_APP_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_KEY=
SHOPIFY_ADMIN_API_SECRET=
CREDENTIAL_ENCRYPTION_KEY=
CLICKPESA_SANDBOX_BASE_URL=https://api.clickpesa.com/third-parties
CLICKPESA_LIVE_BASE_URL=https://api.clickpesa.com/third-parties
SHOPIFY_REQUIRE_MTLS=true
SHOPIFY_MTLS_PROXY_HEADER=x-client-certificate-verified
SHOPIFY_MTLS_PROXY_SUCCESS_VALUE=SUCCESS
JOB_SHARED_SECRET=
CLICKPESA_SUPPORTS_REFUNDS=false
CLICKPESA_SUPPORTS_CAPTURES=false
CLICKPESA_SUPPORTS_VOIDS=false
