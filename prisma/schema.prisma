generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClickPesaEnvironment {
  SANDBOX
  LIVE
}

enum PaymentKind {
  SALE
  AUTHORIZATION
}

enum PaymentLifecycleState {
  RECEIVED
  REDIRECT_READY
  REDIRECTED
  PENDING
  RESOLVED
  REJECTED
  FAILED
  CANCELLED
  RECONCILING
}

enum OperationState {
  RECEIVED
  PENDING
  RESOLVED
  REJECTED
  BLOCKED
}

enum EventSource {
  SHOPIFY
  CLICKPESA
  SYSTEM
}

enum AuditLevel {
  INFO
  WARN
  ERROR
}

model Shop {
  id              String           @id @default(cuid())
  shopDomain      String           @unique
  accessToken     String?
  installedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  merchantConfig  MerchantConfig?
  paymentSessions PaymentSession[]
  webhookEvents   WebhookEvent[]
  auditLogs       AuditLog[]
}

model MerchantConfig {
  id                String               @id @default(cuid())
  shopId            String               @unique
  environment       ClickPesaEnvironment @default(SANDBOX)
  isProviderReady   Boolean              @default(false)
  checksumEnabled   Boolean              @default(false)
  callbackBaseUrl   String?
  returnUrlOverride String?
  cancelUrlOverride String?
  supportEmail      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  shop              Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  credentials       ClickPesaCredential?
}

model ClickPesaCredential {
  id                   String         @id @default(cuid())
  merchantConfigId     String         @unique
  encryptedClientId    String
  encryptedApiKey      String
  encryptedChecksumKey String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  merchantConfig       MerchantConfig @relation(fields: [merchantConfigId], references: [id], onDelete: Cascade)
}

model PaymentSession {
  id                        String                @id @default(cuid())
  shopId                    String
  shopifyPaymentSessionId   String                @unique
  shopifyPaymentSessionGid  String                @unique
  paymentGroupId            String
  shopifySessionId          String?
  requestId                 String?
  amount                    Decimal               @db.Decimal(18, 2)
  currency                  String
  paymentKind               PaymentKind
  state                     PaymentLifecycleState @default(RECEIVED)
  testMode                  Boolean               @default(false)
  merchantLocale            String?
  customerEmail             String?
  customerPhone             String?
  billingAddress            Json?
  shippingAddress           Json?
  cancelUrl                 String?
  redirectUrl               String?
  clickpesaOrderReference   String?               @unique
  clickpesaPaymentReference String?               @unique
  clickpesaCheckoutLink     String?
  clickpesaStatus           String?
  nextActionRedirectUrl     String?
  resolvedAt                DateTime?
  rejectedAt                DateTime?
  pendingAt                 DateTime?
  lastReconciledAt          DateTime?
  lastError                 String?
  metadata                  Json?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  shop                      Shop                  @relation(fields: [shopId], references: [id], onDelete: Restrict)
  attempts                  PaymentAttempt[]
  statusEvents              PaymentStatusEvent[]
  webhookEvents             WebhookEvent[]
  refundSessions            RefundSession[]
  captureSessions           CaptureSession[]
  voidSessions              VoidSession[]
  auditLogs                 AuditLog[]
}

model PaymentAttempt {
  id               String         @id @default(cuid())
  paymentSessionId String
  attemptNumber    Int
  requestId        String?
  requestPayload   Json?
  responsePayload  Json?
  createdAt        DateTime       @default(now())
  paymentSession   PaymentSession @relation(fields: [paymentSessionId], references: [id], onDelete: Cascade)

  @@unique([paymentSessionId, attemptNumber])
}

model PaymentStatusEvent {
  id                String         @id @default(cuid())
  paymentSessionId  String
  source            EventSource
  status            String
  externalReference String?
  rawPayload        Json?
  createdAt         DateTime       @default(now())
  paymentSession    PaymentSession @relation(fields: [paymentSessionId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id               String          @id @default(cuid())
  shopId           String?
  paymentSessionId String?
  provider         String          @default("CLICKPESA")
  idempotencyKey   String          @unique
  eventType        String
  verified         Boolean         @default(false)
  rawBody          String
  payload          Json?
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime        @default(now())
  shop             Shop?           @relation(fields: [shopId], references: [id], onDelete: SetNull)
  paymentSession   PaymentSession? @relation(fields: [paymentSessionId], references: [id], onDelete: SetNull)
}

model RefundSession {
  id                      String         @id @default(cuid())
  paymentSessionId        String
  shopifyRefundSessionId  String         @unique
  shopifyRefundSessionGid String         @unique
  amount                  Decimal        @db.Decimal(18, 2)
  currency                String
  state                   OperationState @default(RECEIVED)
  payload                 Json?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  paymentSession          PaymentSession @relation(fields: [paymentSessionId], references: [id], onDelete: Cascade)
}

model CaptureSession {
  id                       String         @id @default(cuid())
  paymentSessionId         String
  shopifyCaptureSessionId  String         @unique
  shopifyCaptureSessionGid String         @unique
  amount                   Decimal        @db.Decimal(18, 2)
  currency                 String
  state                    OperationState @default(RECEIVED)
  payload                  Json?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  paymentSession           PaymentSession @relation(fields: [paymentSessionId], references: [id], onDelete: Cascade)
}

model VoidSession {
  id                    String         @id @default(cuid())
  paymentSessionId      String
  shopifyVoidSessionId  String         @unique
  shopifyVoidSessionGid String         @unique
  state                 OperationState @default(RECEIVED)
  payload               Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  paymentSession        PaymentSession @relation(fields: [paymentSessionId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id               String          @id @default(cuid())
  shopId           String?
  paymentSessionId String?
  level            AuditLevel      @default(INFO)
  action           String
  actor            String
  message          String
  context          Json?
  createdAt        DateTime        @default(now())
  shop             Shop?           @relation(fields: [shopId], references: [id], onDelete: SetNull)
  paymentSession   PaymentSession? @relation(fields: [paymentSessionId], references: [id], onDelete: SetNull)
}

model IdempotencyRecord {
  id        String   @id @default(cuid())
  scope     String
  recordKey String
  checksum  String?
  response  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, recordKey])
}
